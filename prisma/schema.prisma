  subtotal               Decimal          @db.Decimal(12, 2)
  exchangeSubtotal       Decimal          @default("0") @map("exchange_subtotal") @db.Decimal(12, 2)
  returnedTaxAmount      Decimal          @default("0") @map("returned_tax_amount") @db.Decimal(12, 2)
