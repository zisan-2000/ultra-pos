model Sale {
  id               String      @id @default(uuid()) @db.Uuid
  shopId           String      @map("shop_id") @db.Uuid
  customerId       String?     @map("customer_id") @db.Uuid
  queueTokenSource QueueToken? @relation("QueueTokenSale")
  invoiceNo        String?     @map("invoice_no")
  invoiceIssuedAt  DateTime?   @map("invoice_issued_at") @db.Timestamptz(6)
  saleDate         DateTime    @default(now()) @map("sale_date") @db.Timestamptz(6)
  businessDate     DateTime?   @map("business_date") @db.Date
  subtotalAmount   Decimal     @default(0) @map("subtotal_amount") @db.Decimal(12, 2)
  discountType     String?     @map("discount_type")
  discountValue    Decimal?    @map("discount_value") @db.Decimal(12, 2)
  discountAmount   Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxableAmount    Decimal     @default(0) @map("taxable_amount") @db.Decimal(12, 2)
  taxLabel         String?     @map("tax_label")
  taxRate          Decimal?    @map("tax_rate") @db.Decimal(5, 2)
  taxAmount        Decimal     @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount      Decimal     @map("total_amount") @db.Decimal(12, 2)
  paymentMethod    String      @default("cash") @map("payment_method")
  dueDate          DateTime?   @map("due_date") @db.Date
  paidAmount       Decimal     @default(0) @map("paid_amount") @db.Decimal(12, 2)
  note             String?
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  status           String      @default("COMPLETED")
  voidReason       String?     @map("void_reason")
  voidAt           DateTime?   @map("void_at") @db.Timestamptz(6)
  voidByUserId     String?     @map("void_by_user_id")

  shop          Shop             @relation(fields: [shopId], references: [id])
  customer      Customer?        @relation(fields: [customerId], references: [id])
  saleItems     SaleItem[]
  returns       SaleReturn[]
  ledgerEntries CustomerLedger[]

  @@unique([shopId, invoiceNo], map: "uq_sales_shop_invoice_no")
  @@index([shopId], map: "idx_sales_shop")
  @@index([shopId, invoiceNo], map: "idx_sales_shop_invoice")
  @@index([shopId, createdAt, id], map: "idx_sales_shop_created_id")
  @@index([shopId, status, createdAt], map: "idx_sales_shop_status_created")
  @@index([shopId, saleDate], map: "idx_sales_shop_sale_date")
  @@index([shopId, status, saleDate], map: "idx_sales_shop_status_sale_date")
  @@index([shopId, businessDate], map: "idx_sales_shop_business_date")
  @@index([shopId, status, businessDate], map: "idx_sales_shop_status_business_date")
  @@index([customerId], map: "idx_sales_customer")
  @@index([shopId, paymentMethod, dueDate], map: "idx_sales_shop_payment_due")
  @@map("sales")
}

model SaleItem {
  id                  String   @id @default(uuid()) @db.Uuid
  saleId              String   @map("sale_id") @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  variantId           String?  @map("variant_id") @db.Uuid
  productNameSnapshot String?  @map("product_name_snapshot")
  quantity            Decimal  @db.Decimal(12, 2)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 2)
  costAtSale          Decimal? @map("cost_at_sale") @db.Decimal(12, 2)
  // Prisma doesn't have a first-class generated column annotation; we'll add
  // the `generated always as (quantity * unit_price) stored` via SQL migration.
  // FIXED: Removed dbgenerated default (Neon/Postgres does not allow column refs in DEFAULT)
  lineTotal           Decimal  @map("line_total") @db.Decimal(12, 2)

  sale          Sale            @relation(fields: [saleId], references: [id])
  product       Product         @relation(fields: [productId], references: [id])
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  returnItems   SaleReturnItem[]
  serialNumbers SerialNumber[]
  batchAllocations BatchAllocation[]
  consumedRemnants RemnantPiece[]

  @@index([saleId], map: "idx_sale_items_sale")
  @@index([productId], map: "idx_sale_items_product")
  @@index([saleId, productId], map: "idx_sale_items_sale_product")
  @@index([variantId], map: "idx_sale_items_variant")
  @@map("sale_items")
}

