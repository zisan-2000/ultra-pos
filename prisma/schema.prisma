generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================
// BEST ROLES SYSTEM
// ======================
model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  users           User[]           @relation("UserRoles")
  rolePermissions RolePermission[]
}

model Permission {
  id              String                   @id @default(cuid())
  name            String                   @unique
  description     String?
  rolePermissions RolePermission[]
  userOverrides   UserPermissionOverride[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserPermissionOverride {
  userId       String
  permissionId String
  allowed      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User       @relation(fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([userId, permissionId])
  @@index([permissionId], map: "idx_user_permission_overrides_permission")
  @@map("user_permission_overrides")
}

// -----------------------
// BetterAuth core models
// -----------------------
model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?  @map("password_hash")
  name          String?
  image         String?
  shopLimit     Int      @default(1) @map("shop_limit")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  accounts           Account[]
  sessions           Session[]
  verifications      Verification[]
  adminSyncActions   AdminSyncAction[]
  createdSaleReturns SaleReturn[] @relation("SaleReturnCreatedBy")
  createdPurchaseReturns PurchaseReturn[] @relation("PurchaseReturnCreatedBy")
  impersonationAuditsStarted ImpersonationAudit[] @relation("ImpersonationAuditActor")
  impersonationAuditsTargeted ImpersonationAudit[] @relation("ImpersonationAuditTarget")
  impersonationAuditsEnded   ImpersonationAudit[] @relation("ImpersonationAuditEndedBy")

  roles               Role[]                   @relation("UserRoles")
  permissionOverrides UserPermissionOverride[]
  ownedSubscriptions  ShopSubscription[]       @relation("OwnerSubscriptions")
  ownedInvoices       Invoice[]                @relation("OwnerInvoices")
  paymentRequests     BillingPaymentRequest[]  @relation("OwnerPaymentRequests")
  copilotConversations OwnerCopilotConversation[]
  copilotRuns        OwnerCopilotRun[]
  shopCreationRequestsOwned ShopCreationRequest[] @relation("ShopCreationRequestOwner")
  shopCreationRequestsMade ShopCreationRequest[] @relation("ShopCreationRequestRequester")
  shopCreationRequestsDecided ShopCreationRequest[] @relation("ShopCreationRequestDecider")
  featureAccessRequests FeatureAccessRequest[] @relation("FeatureAccessRequestRequester")
  decidedFeatureAccessRequests FeatureAccessRequest[] @relation("FeatureAccessRequestDecider")
  ownedFeatureAccessRequests FeatureAccessRequest[] @relation("FeatureAccessRequestOwner")
  shops               Shop[]                   @relation("OwnerShops")
  supportTicketsCreated SupportTicket[]        @relation("TicketCreatedBy")
  supportTicketsAssigned SupportTicket[]       @relation("TicketAssignedTo")
  supportTicketReplies SupportTicketReply[]

  // User hierarchy: who created this user
  createdBy     String? @map("created_by")
  createdByUser User?   @relation("CreatedUsers", fields: [createdBy], references: [id])
  createdUsers  User[]  @relation("CreatedUsers")

  // Staff belongs to exactly one shop (optional for non-staff users)
  staffShopId String? @map("staff_shop_id") @db.Uuid
  staffShop   Shop?   @relation("StaffShop", fields: [staffShopId], references: [id])

  @@map("users")
}

model Account {
  id             String    @id @default(cuid())
  accountId      String?   @map("account_id")
  providerId     String    @map("provider_id")
  providerUserId String    @default("") @map("provider_user_id")
  userId         String    @map("user_id")
  accessToken    String?   @map("access_token")
  refreshToken   String?   @map("refresh_token")
  idToken        String?   @map("id_token")
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)
  scope          String?
  password       String?
  profile        Json?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@unique([providerId, providerUserId])
  @@map("accounts")
}

model Session {
  id             String   @id @default(cuid())
  token          String   @unique
  userId         String   @map("user_id")
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  impersonatedBy String?  @map("impersonated_by")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Verification {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  token      String   @unique
  identifier String
  expiresAt  DateTime @map("expires_at") @db.Timestamptz(6)
  type       String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id])

  @@map("verifications")
}

model ImpersonationAudit {
  id               String    @id @default(cuid())
  actorUserId      String    @map("actor_user_id")
  targetUserId     String    @map("target_user_id")
  startedSessionId String?   @map("started_session_id")
  reason           String?
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt          DateTime? @map("ended_at") @db.Timestamptz(6)
  endedByUserId    String?   @map("ended_by_user_id")
  status           String    @default("active")

  actorUser   User  @relation("ImpersonationAuditActor", fields: [actorUserId], references: [id])
  targetUser  User  @relation("ImpersonationAuditTarget", fields: [targetUserId], references: [id])
  endedByUser User? @relation("ImpersonationAuditEndedBy", fields: [endedByUserId], references: [id])

  @@index([actorUserId], map: "idx_impersonation_audits_actor_user_id")
  @@index([targetUserId], map: "idx_impersonation_audits_target_user_id")
  @@index([status], map: "idx_impersonation_audits_status")
  @@index([startedAt], map: "idx_impersonation_audits_started_at")
  @@map("impersonation_audits")
}

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String    @map("public_key")
  privateKey String    @map("private_key")
  alg        String?   @map("alg")
  crv        String?   @map("crv")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)

  @@map("jwks")
}

model Shop {
  id                  String   @id @default(uuid()) @db.Uuid
  ownerId             String   @map("owner_id")
  name                String
  address             String?
  phone               String?
  businessType        String   @default("tea_stall") @map("business_type")
  inventoryFeatureEntitled Boolean @default(false) @map("inventory_feature_entitled")
  inventoryEnabled    Boolean  @default(false) @map("inventory_enabled")
  cogsFeatureEntitled Boolean @default(false) @map("cogs_feature_entitled")
  cogsEnabled         Boolean @default(false) @map("cogs_enabled")
  closingTime         String?  @map("closing_time")
  salesInvoiceEntitled Boolean @default(false) @map("sales_invoice_entitled")
  salesInvoiceEnabled Boolean  @default(false) @map("sales_invoice_enabled")
  salesInvoicePrefix  String?  @map("sales_invoice_prefix")
  salesInvoicePrintSize String @default("thermal-80") @map("sales_invoice_print_size")
  nextSalesInvoiceSeq Int      @default(1) @map("next_sales_invoice_seq")
  saleReturnPrefix    String?  @map("sale_return_prefix")
  nextSaleReturnSeq   Int      @default(1) @map("next_sale_return_seq")
  queueTokenEntitled  Boolean  @default(false) @map("queue_token_entitled")
  queueTokenEnabled   Boolean  @default(false) @map("queue_token_enabled")
  queueTokenPrefix    String?  @map("queue_token_prefix")
  queueWorkflow       String?  @map("queue_workflow")
  discountFeatureEntitled Boolean @default(false) @map("discount_feature_entitled")
  discountEnabled      Boolean @default(false) @map("discount_enabled")
  taxFeatureEntitled  Boolean  @default(false) @map("tax_feature_entitled")
  taxEnabled          Boolean  @default(false) @map("tax_enabled")
  taxLabel            String?  @map("tax_label")
  taxRate             Decimal  @default(0) @map("tax_rate") @db.Decimal(5, 2)
  barcodeFeatureEntitled Boolean @default(false) @map("barcode_feature_entitled")
  barcodeScanEnabled  Boolean  @default(false) @map("barcode_scan_enabled")
  smsSummaryEntitled  Boolean  @default(false) @map("sms_summary_entitled")
  smsSummaryEnabled   Boolean  @default(false) @map("sms_summary_enabled")
  nextQueueTokenSeq   Int      @default(1) @map("next_queue_token_seq")
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner            User                    @relation("OwnerShops", fields: [ownerId], references: [id])
  products         Product[]
  productVariants  ProductVariant[]
  productUnitConversions ProductUnitConversion[]
  queueTokens      QueueToken[]
  sales            Sale[]
  saleReturns      SaleReturn[]
  purchases        Purchase[]
  purchaseReturns  PurchaseReturn[]
  suppliers        Supplier[]
  supplierLedger   SupplierLedger[]
  purchasePayments PurchasePayment[]
  expenses         Expense[]
  cashEntries      CashEntry[]
  customers        Customer[]
  customerLedger   CustomerLedger[]
  copilotConversations OwnerCopilotConversation[]
  copilotRuns      OwnerCopilotRun[]
  staffMembers     User[]                  @relation("StaffShop")
  subscription     ShopSubscription?
  invoices         Invoice[]
  paymentRequests  BillingPaymentRequest[]
  featureAccessRequests FeatureAccessRequest[]
  smsSummaryDispatches SmsSummaryDispatch[]
  supportTickets       SupportTicket[]
  serialNumbers        SerialNumber[]
  batches              Batch[]
  batchAllocations     BatchAllocation[]
  remnantPieces        RemnantPiece[]
  stockAdjustments     StockAdjustment[]

  @@index([ownerId], map: "idx_shops_owner_id")
  @@map("shops")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum InvoiceStatus {
  draft
  open
  paid
  void
  uncollectible
}

enum BillingPaymentRequestStatus {
  pending
  approved
  rejected
}

enum FeatureAccessRequestStatus {
  pending
  approved
  rejected
}

enum SmsDispatchStatus {
  pending
  sent
  failed
  skipped
}

enum CatalogProductSource {
  curated
  imported
  user_submitted
}

enum CatalogImportSourceType {
  csv
  json
  barcode_feed
  supplier_list
  manual
}

enum CatalogImportPayloadFormat {
  json
  csv
}

enum CatalogImportMode {
  skip
  upsert
}

enum CatalogPriceKind {
  retail
  wholesale
  mrp
}

enum CatalogProductMergeMode {
  archive
  delete
}

enum ProductSourceType {
  manual
  template
  catalog
  barcode
}

enum SerialStatus {
  IN_STOCK
  SOLD
  RETURNED
  DAMAGED
}

enum CopilotConversationMessageRole {
  user
  assistant
}

enum OwnerCopilotRunStatus {
  success
  fallback
  blocked
  error
}

model SmsSummaryDispatch {
  id                String            @id @default(uuid()) @db.Uuid
  shopId            String            @map("shop_id") @db.Uuid
  businessDate      DateTime          @map("business_date") @db.Date
  recipientPhone    String            @map("recipient_phone")
  messageBody       String            @map("message_body")
  status            SmsDispatchStatus @default(pending)
  provider          String?           @map("provider")
  providerMessageId String?           @map("provider_message_id")
  errorMessage      String?           @map("error_message")
  attemptCount      Int               @default(0) @map("attempt_count")
  sentAt            DateTime?         @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, businessDate], map: "uq_sms_summary_dispatches_shop_business_date")
  @@index([businessDate, status], map: "idx_sms_summary_dispatches_business_status")
  @@index([shopId, createdAt], map: "idx_sms_summary_dispatches_shop_created")
  @@map("sms_summary_dispatches")
}

model SubscriptionPlan {
  id             String   @id @default(uuid()) @db.Uuid
  key            String   @unique
  name           String
  amount         Decimal  @db.Decimal(12, 2)
  intervalMonths Int      @default(1) @map("interval_months")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscriptions ShopSubscription[]

  @@map("subscription_plans")
}

model ShopSubscription {
  id                 String             @id @default(uuid()) @db.Uuid
  shopId             String             @map("shop_id") @db.Uuid
  ownerId            String             @map("owner_id")
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(trialing)
  currentPeriodStart DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime           @map("current_period_end") @db.Timestamptz(6)
  nextInvoiceAt      DateTime?          @map("next_invoice_at") @db.Timestamptz(6)
  trialEndsAt        DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  graceEndsAt        DateTime?          @map("grace_ends_at") @db.Timestamptz(6)
  canceledAt         DateTime?          @map("canceled_at") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop     Shop             @relation(fields: [shopId], references: [id])
  owner    User             @relation("OwnerSubscriptions", fields: [ownerId], references: [id])
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@unique([shopId], map: "uq_shop_subscriptions_shop_id")
  @@index([ownerId], map: "idx_shop_subscriptions_owner_id")
  @@map("shop_subscriptions")
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  subscriptionId String        @map("subscription_id") @db.Uuid
  shopId         String        @map("shop_id") @db.Uuid
  ownerId        String        @map("owner_id")
  periodStart    DateTime      @map("period_start") @db.Timestamptz(6)
  periodEnd      DateTime      @map("period_end") @db.Timestamptz(6)
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus @default(open)
  dueDate        DateTime      @map("due_date") @db.Timestamptz(6)
  paidAt         DateTime?     @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  subscription    ShopSubscription        @relation(fields: [subscriptionId], references: [id])
  shop            Shop                    @relation(fields: [shopId], references: [id])
  owner           User                    @relation("OwnerInvoices", fields: [ownerId], references: [id])
  payments        InvoicePayment[]
  paymentRequests BillingPaymentRequest[]

  @@unique([subscriptionId, periodStart, periodEnd], map: "uq_billing_invoices_period")
  @@index([shopId], map: "idx_billing_invoices_shop_id")
  @@index([ownerId], map: "idx_billing_invoices_owner_id")
  @@index([status], map: "idx_billing_invoices_status")
  @@index([dueDate], map: "idx_billing_invoices_due_date")
  @@map("billing_invoices")
}

model InvoicePayment {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  method    String
  reference String?
  paidAt    DateTime @map("paid_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId], map: "idx_invoice_payments_invoice_id")
  @@map("invoice_payments")
}

model BillingPaymentRequest {
  id        String                      @id @default(uuid()) @db.Uuid
  invoiceId String                      @map("invoice_id") @db.Uuid
  ownerId   String                      @map("owner_id")
  shopId    String                      @map("shop_id") @db.Uuid
  method    String
  reference String?
  note      String?
  status    BillingPaymentRequestStatus @default(pending)
  createdAt DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt DateTime?                   @map("decided_at") @db.Timestamptz(6)

  invoice Invoice @relation(fields: [invoiceId], references: [id])
  owner   User    @relation("OwnerPaymentRequests", fields: [ownerId], references: [id])
  shop    Shop    @relation(fields: [shopId], references: [id])

  @@index([invoiceId], map: "idx_billing_payment_requests_invoice_id")
  @@index([ownerId], map: "idx_billing_payment_requests_owner_id")
  @@index([status], map: "idx_billing_payment_requests_status")
  @@map("billing_payment_requests")
}

model FeatureAccessRequest {
  id              String                     @id @default(uuid()) @db.Uuid
  shopId          String                     @map("shop_id") @db.Uuid
  ownerId         String                     @map("owner_id")
  requestedByUserId String                   @map("requested_by_user_id")
  featureKey      String                     @map("feature_key")
  reason          String?
  status          FeatureAccessRequestStatus @default(pending)
  decisionNote    String?                    @map("decision_note")
  decidedByUserId String?                    @map("decided_by_user_id")
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt       DateTime?                  @map("decided_at") @db.Timestamptz(6)

  shop            Shop                       @relation(fields: [shopId], references: [id])
  owner           User                       @relation("FeatureAccessRequestOwner", fields: [ownerId], references: [id])
  requestedByUser User                       @relation("FeatureAccessRequestRequester", fields: [requestedByUserId], references: [id])
  decidedByUser   User?                      @relation("FeatureAccessRequestDecider", fields: [decidedByUserId], references: [id])

  @@index([shopId, status], map: "idx_feature_access_requests_shop_status")
  @@index([ownerId, status], map: "idx_feature_access_requests_owner_status")
  @@index([featureKey, status], map: "idx_feature_access_requests_feature_status")
  @@map("feature_access_requests")
}

model ShopCreationRequest {
  id                  String                     @id @default(uuid()) @db.Uuid
  ownerId             String                     @map("owner_id")
  requestedByUserId   String                     @map("requested_by_user_id")
  currentShopCount    Int                        @default(0) @map("current_shop_count")
  primaryShopIdSnapshot String?                  @map("primary_shop_id_snapshot") @db.Uuid
  primaryShopNameSnapshot String?                @map("primary_shop_name_snapshot")
  primaryShopPhoneSnapshot String?               @map("primary_shop_phone_snapshot")
  reason              String?
  status              FeatureAccessRequestStatus @default(pending)
  decisionNote        String?                    @map("decision_note")
  decidedByUserId     String?                    @map("decided_by_user_id")
  approvedLimitAfter  Int?                       @map("approved_limit_after")
  createdAt           DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  decidedAt           DateTime?                  @map("decided_at") @db.Timestamptz(6)

  owner               User                       @relation("ShopCreationRequestOwner", fields: [ownerId], references: [id])
  requestedByUser     User                       @relation("ShopCreationRequestRequester", fields: [requestedByUserId], references: [id])
  decidedByUser       User?                      @relation("ShopCreationRequestDecider", fields: [decidedByUserId], references: [id])

  @@index([ownerId, status], map: "idx_shop_creation_requests_owner_status")
  @@index([status, createdAt], map: "idx_shop_creation_requests_status_created")
  @@map("shop_creation_requests")
}

model BusinessType {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique
  label      String
  isActive   Boolean  @default(true) @map("is_active")
  fieldRules Json     @map("field_rules")
  stockRules Json     @map("stock_rules")
  unitRules  Json     @map("unit_rules")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("business_types")
}

model CatalogImportSource {
  id            String                  @id @default(uuid()) @db.Uuid
  slug          String                  @unique
  name          String
  type          CatalogImportSourceType
  notes         String?
  importedAt    DateTime?               @map("imported_at") @db.Timestamptz(6)
  createdAt     DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  products       CatalogProduct[]
  priceSnapshots CatalogPriceSnapshot[]
  importRuns     CatalogImportRun[]

  @@map("catalog_import_sources")
}

model CatalogProduct {
  id              String               @id @default(uuid()) @db.Uuid
  businessType    String?              @map("business_type")
  name            String
  brand           String?              @db.VarChar(120)
  category        String?
  packSize        String?              @map("pack_size") @db.VarChar(80)
  defaultBaseUnit String?              @map("default_base_unit") @db.VarChar(40)
  imageUrl        String?              @map("image_url")
  popularityScore Int                  @default(0) @map("popularity_score")
  sourceType      CatalogProductSource @default(curated) @map("source_type")
  importSourceId  String?              @map("import_source_id") @db.Uuid
  externalRef     String?              @map("external_ref")
  mergedIntoCatalogProductId String?   @map("merged_into_catalog_product_id") @db.Uuid
  mergedAt        DateTime?            @map("merged_at") @db.Timestamptz(6)
  isActive        Boolean              @default(true) @map("is_active")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  importSource       CatalogImportSource?      @relation(fields: [importSourceId], references: [id], onDelete: SetNull)
  mergedIntoCatalogProduct CatalogProduct?     @relation("CatalogProductMergeParent", fields: [mergedIntoCatalogProductId], references: [id], onDelete: SetNull)
  mergedFromCatalogProducts CatalogProduct[]   @relation("CatalogProductMergeParent")
  aliases            CatalogProductAlias[]
  barcodes           CatalogProductBarcode[]
  priceSnapshots     CatalogPriceSnapshot[]
  templates          BusinessProductTemplate[]
  products           Product[]
  mergeSourceActions CatalogProductMergeAction[] @relation("CatalogProductMergeSourceActions")
  mergeTargetActions CatalogProductMergeAction[] @relation("CatalogProductMergeTargetActions")

  @@index([businessType], map: "idx_catalog_products_business_type")
  @@index([businessType, popularityScore], map: "idx_catalog_products_business_popularity")
  @@index([brand], map: "idx_catalog_products_brand")
  @@index([importSourceId], map: "idx_catalog_products_import_source_id")
  @@index([isActive], map: "idx_catalog_products_is_active")
  @@index([mergedIntoCatalogProductId], map: "idx_catalog_products_merged_into")
  @@index([mergedAt], map: "idx_catalog_products_merged_at")
  @@map("catalog_products")
}

model CatalogProductAlias {
  id               String   @id @default(uuid()) @db.Uuid
  catalogProductId String   @map("catalog_product_id") @db.Uuid
  alias            String
  locale           String?  @db.VarChar(16)
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  catalogProduct CatalogProduct @relation(fields: [catalogProductId], references: [id], onDelete: Cascade)

