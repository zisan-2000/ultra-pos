// ======================
// SUPPORT TICKET SYSTEM
// ======================

enum SupportTicketStatus {
  open
  in_progress
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
}

enum SupportTicketCategory {
  technical
  billing
  feature_request
  other
}

model SupportTicket {
  id               String                @id @default(uuid()) @db.Uuid
  ticketNumber     Int                   @default(autoincrement()) @map("ticket_number")
  shopId           String                @map("shop_id") @db.Uuid
  createdByUserId  String                @map("created_by_user_id")
  assignedToUserId String?               @map("assigned_to_user_id")
  title            String
  description      String
  category         SupportTicketCategory @default(other)
  priority         SupportTicketPriority @default(normal)
  status           SupportTicketStatus   @default(open)
  resolvedAt       DateTime?             @map("resolved_at") @db.Timestamptz(6)
  resolvedNote     String?               @map("resolved_note")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop       Shop                 @relation(fields: [shopId], references: [id])
  createdBy  User                 @relation("TicketCreatedBy", fields: [createdByUserId], references: [id])
  assignedTo User?                @relation("TicketAssignedTo", fields: [assignedToUserId], references: [id])
  replies    SupportTicketReply[]

  @@index([shopId], map: "idx_support_tickets_shop_id")
  @@index([status, createdAt], map: "idx_support_tickets_status_created")
  @@index([createdByUserId], map: "idx_support_tickets_created_by")
  @@map("support_tickets")
}

model SupportTicketReply {
  id        String        @id @default(uuid()) @db.Uuid
  ticketId  String        @map("ticket_id") @db.Uuid
  userId    String        @map("user_id")
  content   String
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId], map: "idx_support_ticket_replies_ticket_id")
  @@map("support_ticket_replies")
}

// ======================
// SERIAL NUMBER TRACKING
// ======================

model SerialNumber {
  id             String       @id @default(uuid()) @db.Uuid
  shopId         String       @map("shop_id") @db.Uuid
  productId      String       @map("product_id") @db.Uuid
  variantId      String?      @map("variant_id") @db.Uuid
  serialNo       String       @map("serial_no") @db.VarChar(120)
  status         SerialStatus @default(IN_STOCK)
  purchaseItemId String?      @map("purchase_item_id") @db.Uuid
  saleItemId     String?      @map("sale_item_id") @db.Uuid
  note           String?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop         Shop            @relation(fields: [shopId], references: [id])
  product      Product         @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  purchaseItem PurchaseItem?   @relation(fields: [purchaseItemId], references: [id], onDelete: SetNull)
  saleItem     SaleItem?       @relation(fields: [saleItemId], references: [id], onDelete: SetNull)

  @@unique([shopId, productId, serialNo], map: "uq_serial_numbers_shop_product_serial")
  @@index([shopId, productId, status], map: "idx_serial_numbers_shop_product_status")
  @@index([saleItemId], map: "idx_serial_numbers_sale_item")
  @@index([purchaseItemId], map: "idx_serial_numbers_purchase_item")
  @@map("serial_numbers")
}

// ======================
// BATCH / LOT TRACKING
// ======================

model Batch {
  id             String   @id @default(uuid()) @db.Uuid
  shopId         String   @map("shop_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  variantId      String?  @map("variant_id") @db.Uuid
  batchNo        String   @map("batch_no") @db.VarChar(120)
  expiryDate     DateTime? @map("expiry_date") @db.Date
  purchaseItemId String?  @map("purchase_item_id") @db.Uuid
  totalQty       Decimal  @map("total_qty") @db.Decimal(12, 2)
  remainingQty   Decimal  @map("remaining_qty") @db.Decimal(12, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop         Shop            @relation(fields: [shopId], references: [id])
  product      Product         @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])
  purchaseItem PurchaseItem?   @relation(fields: [purchaseItemId], references: [id], onDelete: SetNull)
  allocations  BatchAllocation[]

  @@unique([shopId, productId, batchNo], map: "uq_batches_shop_product_batchno")
  @@index([shopId, productId, remainingQty], map: "idx_batches_shop_product_remaining")
  @@index([shopId, expiryDate, remainingQty], map: "idx_batches_shop_expiry_remaining")
  @@index([purchaseItemId], map: "idx_batches_purchase_item")
  @@map("batches")
}

model BatchAllocation {
  id                String   @id @default(uuid()) @db.Uuid
  shopId            String   @map("shop_id") @db.Uuid
  batchId           String   @map("batch_id") @db.Uuid
  saleItemId        String   @map("sale_item_id") @db.Uuid
  quantityAllocated Decimal  @map("quantity_allocated") @db.Decimal(12, 2)
  quantityReturned  Decimal  @default("0") @map("quantity_returned") @db.Decimal(12, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop     Shop     @relation(fields: [shopId], references: [id])
  batch    Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  saleItem SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)

  @@index([shopId, batchId], map: "idx_batch_allocations_shop_batch")
  @@index([saleItemId], map: "idx_batch_allocations_sale_item")
  @@index([batchId, createdAt], map: "idx_batch_allocations_batch_created")
  @@map("batch_allocations")
}

model RemnantPiece {
  id                 String    @id @default(uuid()) @db.Uuid
  shopId             String    @map("shop_id") @db.Uuid
  productId          String    @map("product_id") @db.Uuid
  variantId          String?   @map("variant_id") @db.Uuid
  originalLength     Decimal   @map("original_length") @db.Decimal(12, 2)
  remainingLength    Decimal   @map("remaining_length") @db.Decimal(12, 2)
  source             String    @db.VarChar(40)
  sourceRef          String?   @map("source_ref") @db.VarChar(120)
  status             String    @default("ACTIVE") @db.VarChar(20)
  consumedSaleItemId String?   @map("consumed_sale_item_id") @db.Uuid
  note               String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop             Shop            @relation(fields: [shopId], references: [id])
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant          ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  consumedSaleItem SaleItem?       @relation(fields: [consumedSaleItemId], references: [id], onDelete: SetNull)

  @@index([shopId, productId, status], map: "idx_remnant_pieces_shop_product_status")
  @@index([shopId, variantId, status], map: "idx_remnant_pieces_shop_variant_status")
  @@index([consumedSaleItemId], map: "idx_remnant_pieces_consumed_sale_item")
  @@map("remnant_pieces")
}

// ======================
// STOCK ADJUSTMENTS
// ======================

model StockAdjustment {
  id             String   @id @default(uuid()) @db.Uuid
  shopId         String   @map("shop_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  variantId      String?  @map("variant_id") @db.Uuid
  reason         String   @db.VarChar(80)
  note           String?
  quantityChange Decimal  @map("quantity_change") @db.Decimal(12, 2)
  previousQty    Decimal  @map("previous_qty") @db.Decimal(12, 2)
  newQty         Decimal  @map("new_qty") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop    Shop            @relation(fields: [shopId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([shopId, createdAt], map: "idx_stock_adjustments_shop_created")
  @@index([productId], map: "idx_stock_adjustments_product")
  @@map("stock_adjustments")
}
