  dueAdjustmentAmount    Decimal          @default("0") @map("due_adjustment_amount") @db.Decimal(12, 2)
  additionalDueAmount    Decimal          @default("0") @map("additional_due_amount") @db.Decimal(12, 2)
  businessDate           DateTime?        @map("business_date") @db.Date
  createdByUserId        String           @map("created_by_user_id")
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop          Shop                     @relation(fields: [shopId], references: [id])
  sale          Sale                     @relation(fields: [saleId], references: [id])
  createdByUser User                     @relation("SaleReturnCreatedBy", fields: [createdByUserId], references: [id])
  items         SaleReturnItem[]
  exchangeItems SaleReturnExchangeItem[]

  @@unique([shopId, returnNo], map: "uq_sale_returns_shop_return_no")
  @@index([shopId, businessDate], map: "idx_sale_returns_shop_business_date")
  @@index([saleId], map: "idx_sale_returns_sale")
