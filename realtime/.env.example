# Realtime server
REALTIME_PORT=4001
REALTIME_API_SECRET=change-me
REALTIME_ALLOWED_ORIGINS=http://localhost:3000
REALTIME_REDIS_URL=
REALTIME_EMIT_WINDOW_MS=60000
# Recommended starter for early production growth.
REALTIME_EMIT_MAX=1500
REALTIME_EMIT_METRICS_LOG_INTERVAL_MS=60000
REALTIME_AUDIT_LOG=1

# Auth + DB
DATABASE_URL=postgresql://user:password@localhost:5432/pos
BETTER_AUTH_SECRET=change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional
SLOW_QUERY_THRESHOLD_MS=500

# AI copilot (Phase 1, server-side only)
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
OWNER_COPILOT_LLM_ENABLED=1
OWNER_COPILOT_LLM_TIMEOUT_MS=8000
